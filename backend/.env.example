# ============================
# MOYÉ Backend - Configuration
# ============================

# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database PostgreSQL (obligatoire pour le RAG / contexte culturel)
# Démarrer PostgreSQL : docker run -d -p 5432:5432 -e POSTGRES_USER=moye_user -e POSTGRES_PASSWORD=moye_password -e POSTGRES_DB=moye_db postgres:16
# Puis : cd backend && npx prisma migrate dev
DATABASE_URL="postgresql://moye_user:moye_password@localhost:5432/moye_db"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-256-bits
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# CORS - Frontend URL
CORS_ORIGIN=http://localhost:3000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50mb

# IA Integration (future)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
